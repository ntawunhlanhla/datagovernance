# ===== Django =====
DJANGO_SECRET_KEY=change-me-please-generate-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com

# ===== Postgres (portal) =====
POSTGRES_DB=metadata
POSTGRES_USER=metadata
POSTGRES_PASSWORD=metadata

# ===== MinIO =====
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ===== Marquez =====
MARQUEZ_NAMESPACE=metadata-governance

# ===== Emergent LLM (domain-driven dataset designer) =====
EMERGENT_LLM_KEY=sk-emergent-fCfDb84C794BeA613F
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ===== Catalog provider =====
# openmetadata (default — runs in Docker) | alation | mock
CATALOG_PROVIDER=openmetadata

# ===== OpenMetadata =====
OPENMETADATA_BASE_URL=http://openmetadata-server:8585
OPENMETADATA_PUBLIC_URL=http://localhost:8585
OPENMETADATA_SERVICE_NAME=MetadataGovernancePlatform
# Paste here AFTER first boot:
#   1. Open http://localhost:8585  (login admin@open-metadata.org / admin)
#   2. Settings → Bots → ingestion-bot → "Copy" Token
#   3. Paste below and run: docker compose restart metadata-portal celery-worker data-generator
OPENMETADATA_JWT_TOKEN=

# ===== Alation (used only if CATALOG_PROVIDER=alation) =====
ALATION_MODE=mock
ALATION_BASE_URL=
ALATION_REFRESH_TOKEN=
ALATION_USER_ID=
ALATION_DATA_SOURCE_ID=
ALATION_FOLDER_ID=

# ===== AWS (optional, for Athena/Glue/S3 connectors) =====
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_ATHENA_OUTPUT=
AWS_GLUE_DATABASE=
